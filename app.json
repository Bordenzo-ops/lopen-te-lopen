{
  "expo": {
    "name": "Lopen te Lopen",
    "slug": "lopen-te-lopen",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "lopentelopen",
    "userInterfaceStyle": "dark",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.lopentelopen.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Lopen te Lopen gebruikt je locatie om je route, afstand en tempo bij te houden tijdens het hardlopen, ook als je scherm vergrendeld is.",
        "UIBackgroundModes": [
          "audio",
          "location"
        ],
        "ITSAppUsesNonExemptEncryption": false,
        "LSApplicationQueriesSchemes": [
          "instagram-stories"
        ]
      },
      "buildNumber": "9"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0F1A"
      },
      "package": "com.lopentelopen.app",
      "versionCode": 15,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_LOCATION",
        "WRITE_EXTERNAL_STORAGE",
        "android.permission.health.WRITE_EXERCISE",
        "android.permission.health.WRITE_DISTANCE",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyC_mehbQycogOJ_beEnnji-I9ZvjEIT4os"
        }
      }
    },
    "plugins": [
      "expo-router",
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 26
          }
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Lopen te Lopen gebruikt je locatie om je route, afstand en tempo bij te houden tijdens het hardlopen, ook als je scherm vergrendeld is.",
          "isIosBackgroundLocationEnabled": true
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Geef toegang tot je fotobibliotheek om je run-kaart op te slaan.",
          "savePhotosPermission": "Lopen te Lopen wil je run-kaart opslaan in je fotobibliotheek."
        }
      ],
      "expo-font",
      "expo-sharing",
      "expo-status-bar",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash.png",
          "resizeMode": "contain",
          "backgroundColor": "#0A0F1A"
        }
      ],
      "expo-asset",
      "react-native-health-connect",
      "expo-secure-store",
      [
        "@sentry/react-native",
        {
          "organization": "dronevision-studios",
          "project": "android"
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "77bb6e1a-d692-48e8-8206-3cb6cdcea770"
      }
    }
  }
}
