# Kopieer dit bestand naar .env en vul je eigen sleutels in.
# .env staat in .gitignore en wordt dus nooit meegecommit.

# Supabase backend voor account en synchronisatie (optioneel).
# Zonder deze sleutels werkt de app volledig offline.
# Vind ze in je Supabase-project: Project Settings, API.
# Aanmaken en migraties draaien: zie docs/SUPABASE_SETUP.md
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# RevenueCat voor premium-abonnementen via Play Billing (optioneel).
# Zonder deze sleutel valt de app stilletjes terug op geen premium.
# Gebruik de Google Play (Android) public SDK key uit RevenueCat,
# Project Settings, API keys. Setup: zie docs/REVENUECAT_SETUP.md
EXPO_PUBLIC_REVENUECAT_API_KEY=

# iOS: de Apple (App Store) public SDK key uit RevenueCat (begint met appl_).
# Alleen nodig voor iOS-builds. Zonder deze key valt iOS terug op de Android-key.
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=

# Geheim voor de stats-functie (marketingstatistieken), optioneel.
# Moet exact hetzelfde sterke geheim zijn als de Supabase-secret STATS_SECRET
# van de edge function stats. Wordt gebruikt door de wekelijkse
# statsbriefing om zichzelf bij die functie te authenticeren.
STATS_SECRET=

# Sentry crashrapportage (optioneel). Leeg laten = geen crashrapportage,
# de app werkt dan gewoon door met alleen de eigen Nederlandse
# foutmelding bij een onverwachte crash. DSN vind je in je Sentry-project
# onder Settings, Client Keys (DSN).
EXPO_PUBLIC_SENTRY_DSN=
